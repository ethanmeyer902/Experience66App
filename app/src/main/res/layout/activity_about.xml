<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary"
                android:contentDescription="back" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="About"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Experience 66"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Experience 66 is a mobile app that brings Route 66 to life through location-based storytelling. Discover landmarks, explore historical archives, and navigate Route 66 with an interactive map."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="16dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Archive Information"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historical information, images, and archive content in Experience 66 come from Northern Arizona University Cline Library Special Collections and Archives. This app uses those materials from CONTENTdm to connect Route 66 landmarks with trusted archival content."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="16dp" />
        <!-- Team Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Created by the Experience66 team:"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="312dp"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="Ethan Meyer, Manjot Kaur, Moraa Morara, Nasya Valenzuela"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clients:"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="16dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mike Taylor, Mark Manone, Sean Evans"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:paddingBottom="16dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 1.0"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>